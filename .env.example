# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (production)
NEXT_PUBLIC_BASE_URL=https://tiki-boat.com

# SMTP Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@tiki-boat.com
SMTP_PASS=your_app_password
EMAIL_FROM=contact@tiki-boat.com
EMAIL_ADMIN=contact@tiki-boat.com

# NextAuth (admin panel)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=https://tiki-boat.com

# Admin credentials
ADMIN_EMAIL=admin@tiki-boat.com
ADMIN_PASSWORD=change_this_password
